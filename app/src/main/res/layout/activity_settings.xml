<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="81dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp" >

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/gesture_delays"
                android:textColor="@color/SettingsTextcolor"
                android:textSize="28sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Volume -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tvVolLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/tvVolValue"
                        android:text="@string/volume_control"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/SettingsTextcolor" />

                    <TextView
                        android:id="@+id/tvVolValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/_500_ms"
                        android:textSize="11sp"
                        android:textColor="@color/SettingsTextcolor"
                        android:textStyle="bold" />
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cooldown_between_volume_steps"
                    android:textColor="#757575"
                    android:textSize="11sp"/>

                <SeekBar
                    android:id="@+id/sbVolDelay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:max="5000"
                    android:progress="500"
                    android:progressTint="@color/SettingsTextcolor"
                    android:thumbTint="@color/SettingsTextcolor" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Next App  -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tvNavLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/tvNavValue"
                        android:text="@string/app_navigation"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/SettingsTextcolor" />
                    <TextView
                        android:id="@+id/tvNavValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/_3000_ms"
                        android:textSize="11sp"
                        android:textColor="@color/SettingsTextcolor"
                        android:textStyle="bold" />
                </RelativeLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cooldown_between_app_navigation_steps"
                    android:textColor="#757575"
                    android:textSize="11sp"/>

                <SeekBar
                    android:id="@+id/sbNextAppDelay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:max="5000"
                    android:progress="3000"
                    android:progressTint="@color/SettingsTextcolor"
                    android:thumbTint="@color/SettingsTextcolor" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Pause/Play  -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tvPausePlayLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/tvPausePlayValue"
                        android:text="@string/pause_play_control"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/SettingsTextcolor" />
                    <TextView
                        android:id="@+id/tvPausePlayValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/_1500_ms"
                        android:textSize="11sp"
                        android:textColor="@color/SettingsTextcolor"
                        android:textStyle="bold" />
                </RelativeLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cooldown_between_each_pause_play"
                    android:textColor="#757575"
                    android:textSize="11sp"/>

                <SeekBar
                    android:id="@+id/sbPausePlayDelay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:max="5000"
                    android:progress="1500"
                    android:progressTint="@color/SettingsTextcolor"
                    android:thumbTint="@color/SettingsTextcolor" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>



        <!-- Next Song -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tvNextSongLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/tvNextSongValue"
                        android:text="@string/next_song_cooldown"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/SettingsTextcolor" />
                    <TextView
                        android:id="@+id/tvNextSongValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/_1900_ms"
                        android:textSize="11sp"
                        android:textColor="@color/SettingsTextcolor"
                        android:textStyle="bold" />
                </RelativeLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cooldown_between_skipping_songs"
                    android:textColor="#757575"
                    android:textSize="11sp"/>

                <SeekBar
                    android:id="@+id/sbNextSongDelay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:max="5000"
                    android:progress="1900"
                    android:progressTint="@color/SettingsTextcolor"
                    android:thumbTint="@color/SettingsTextcolor" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Previous song  -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tvPrevSongLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/tvPrevSongValue"
                        android:text="@string/previous_song_cooldown"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/SettingsTextcolor" />
                    <TextView
                        android:id="@+id/tvPrevSongValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/_1500_ms"
                        android:textSize="11sp"
                        android:textColor="@color/SettingsTextcolor"
                        android:textStyle="bold" />
                </RelativeLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cooldown_for_going_to_previous_song"
                    android:textColor="#757575"
                    android:textSize="11sp"/>

                <SeekBar
                    android:id="@+id/sbPrevDelay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:max="5000"
                    android:progress="1500"
                    android:progressTint="@color/SettingsTextcolor"
                    android:thumbTint="@color/SettingsTextcolor" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Like and Dislike Song -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tvLikeDislikeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@+id/tvLikeDislikeValue"
                        android:text="@string/like_dislike_cooldown"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/SettingsTextcolor" />
                    <TextView
                        android:id="@+id/tvLikeDislikeValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/_1500_ms"
                        android:textSize="11sp"
                        android:textColor="@color/SettingsTextcolor"
                        android:textStyle="bold" />
                </RelativeLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/response_to_like_dislike"
                    android:textColor="#757575"
                    android:textSize="11sp"/>

                <SeekBar
                    android:id="@+id/sbLikeDislikeSongDelay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:max="5000"
                    android:progress="1500"
                    android:progressTint="@color/SettingsTextcolor"
                    android:thumbTint="@color/SettingsTextcolor" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>


    </LinearLayout>
</ScrollView>